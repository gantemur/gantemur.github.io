      {% include "partials/publication.njk" %}
    {% endfor %}
    {% for pub in articles %}
      {% include "partials/publication.njk" %}
    {% endfor %}
  </ol>
</section>

<section>
  <h2>Preprints</h2>
  <ol class="pub-list">
    {% for pub in preprints %}
      {% include "partials/publication.njk" %}
