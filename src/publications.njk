{% set preprints = publications | where("status", "preprint") %}
{% set articles = publications | where("status", "article") %}
{% set published = publications | where("status", "published") %}
{% set accepted = publications | where("status", "accepted") %}

<section>
  <h2>Preprints</h2>
  <ol class="pub-list">
    {% for pub in preprints %}
      {% include "partials/publication.njk" %}
    {% endfor %}
  </ol>
</section>

<section>
  <h2>Published and accepted</h2>
  <ol class="pub-list">
    {% for pub in published %}
      {% include "partials/publication.njk" %}
    {% endfor %}
    {% for pub in accepted %}
      {% include "partials/publication.njk" %}
    {% endfor %}
    {% for pub in articles %}
      {% include "partials/publication.njk" %}
    {% endfor %}
  </ol>
</section>
