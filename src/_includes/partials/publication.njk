<li>
  {% set coauthors = pub | publicationCoauthors %}
  {% set citation = pub | publicationCitation %}
  {% set links = pub | publicationLinks %}

  <strong class="publication-title">{{ pub.title }}</strong>
  {% if coauthors %}
    <span class="publication-coauthors">{{ coauthors | safe }}</span>
  {% endif %}
  {% if citation %}
    <span class="publication-citation">{{ citation | safe }}</span>
  {% endif %}
  {% if links and links.length %}
    <span class="publication-links">
      {% for link in links %}
        <a href="{{ link.url }}">{{ link.label }}</a>{% if not loop.last %} · {% endif %}
      {% endfor %}
    </span>
  {% endif %}
</li>
