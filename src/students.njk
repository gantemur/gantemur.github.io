---
layout: layouts/base.njk
title: Supervision and Mentoring
permalink: /supervision/
---

<h1>Supervision and Mentoring</h1>
<p class="lede narrow">Selected supervision, mentoring, trainee, and student-project records.</p>

{% set graduate = students | studentRelationships("doctoral-student,masters-student") | byStudentYear %}
{% set postdoctoral = students | where("relationship", "postdoctoral-fellow") | byStudentYear %}
{% set allUndergraduate = students | where("relationship", "undergraduate-project") | byStudentYear %}
{% set researchTrainees = allUndergraduate | studentKind("Research trainee") %}
{% set undergraduate = allUndergraduate | excludeStudentKind("Research trainee") %}
{% set writings = students | where("relationship", "student-writing") %}
{% set graduateHasNowAt = graduate | hasNowAt %}
{% set researchTraineesHasNowAt = researchTrainees | hasNowAt %}
{% set undergraduateHasNowAt = undergraduate | hasNowAt %}

{% if postdoctoral.length %}
  <section class="rule-section">
    <h2>Postdoctoral Fellows</h2>
    <ul class="supervision-list">
      {% for fellow in postdoctoral %}
        <li class="supervision-item">
          <p><strong>{{ fellow | linkedPersonName | safe }}</strong>{% if fellow.period %}, {{ fellow.period }}{% elif fellow.year %}, {{ fellow.year }}{% endif %}.</p>
          {% if fellow.background %}<p>{{ fellow.background }}</p>{% endif %}
          {% if fellow.topic %}<p>{{ fellow.topic }}</p>{% endif %}
          {% if fellow.coSupervisors and fellow.coSupervisors.length %}
            <p><span class="supervision-label">Co-advisor:</span> {{ fellow | linkedCoSupervisors | safe }}</p>
          {% endif %}
          {% if fellow.nowAt and fellow.nowAt.label %}
            <p><span class="supervision-label">Now at:</span> <span class="now-at-cell">{{ fellow | renderNowAt | safe }}</span></p>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  </section>
{% endif %}

<section class="rule-section">
  <h2>Graduate Students</h2>
<table class="data-table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Degree</th>
      <th>Year</th>
      <th>Topic</th>
      <th>Co-supervisors</th>
      {% if graduateHasNowAt %}<th>Now at</th>{% endif %}
    </tr>
  </thead>
  <tbody>
    {% for student in graduate %}
      <tr>
        <td>{{ student | linkedPersonName | safe }}</td>
        <td>{{ student.degree }}</td>
        <td>{{ student.yearLabel or student.year or "" }}</td>
        <td>{{ student.topic }}</td>
        <td>{% if student.coSupervisors and student.coSupervisors.length %}{{ student | linkedCoSupervisors | safe }}{% endif %}</td>
        {% if graduateHasNowAt %}<td class="now-at-cell">{{ student | renderNowAt | safe }}</td>{% endif %}
      </tr>
    {% endfor %}
  </tbody>
</table>
</section>

{% if researchTrainees.length %}
  <section class="rule-section">
    <h2>Research Trainees</h2>
    <table class="data-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Year</th>
          <th>Topic</th>
          {% if researchTraineesHasNowAt %}<th>Now at</th>{% endif %}
        </tr>
      </thead>
      <tbody>
        {% for trainee in researchTrainees %}
          <tr>
            <td>{{ trainee | linkedPersonName | safe }}</td>
            <td>{{ trainee.year or "" }}</td>
            <td>{{ trainee.topic }}</td>
            {% if researchTraineesHasNowAt %}<td class="now-at-cell">{{ trainee | renderNowAt | safe }}</td>{% endif %}
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </section>
{% endif %}

<section class="rule-section">
  <h2>Undergraduate Trainees</h2>
  <table class="data-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Year</th>
        <th>Type</th>
        <th>Topic</th>
        {% if undergraduateHasNowAt %}<th>Now at</th>{% endif %}
      </tr>
    </thead>
    <tbody>
      {% for student in undergraduate %}
        <tr>
          <td>{{ student | linkedPersonName | safe }}</td>
          <td>{{ student.year or "" }}</td>
          <td>
            {% set typeLabel = student.kind or student.degree or "" %}
            {{ typeLabel }}{% if student.award %} ({{ student.award }}){% endif %}
          </td>
          <td>
            {% if student.links and student.links.length %}
              <a href="{{ student.links[0].url }}">{{ student.topic }}</a>
            {% else %}
              {{ student.topic }}
            {% endif %}
          </td>
          {% if undergraduateHasNowAt %}<td class="now-at-cell">{{ student | renderNowAt | safe }}</td>{% endif %}
        </tr>
      {% endfor %}
    </tbody>
  </table>
</section>

<section class="rule-section">
  <h2>Student Writings and Projects</h2>
  <table class="data-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Topic</th>
      </tr>
    </thead>
    <tbody>
      {% for item in writings %}
        <tr>
          <td>{{ item.name or "" }}</td>
          <td>
            {% if item.links and item.links.length %}
              <a href="{{ item.links[0].url }}">{{ item.topic }}</a>
            {% else %}
              {{ item.topic }}
            {% endif %}
          </td>
        </tr>
      {% endfor %}
    </tbody>
  </table>
</section>
