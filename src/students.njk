---
layout: layouts/base.njk
title: Students
permalink: /students/
---

<h1>Students</h1>
<p class="lede narrow">Selected supervision and student project records from the academic archive.</p>

{% set doctoral = students | where("relationship", "doctoral-student") %}
{% set masters = students | where("relationship", "masters-student") %}
{% set undergraduate = students | where("relationship", "undergraduate-project") %}
{% set writings = students | where("relationship", "student-writing") %}

<section class="rule-section">
  <h2>Graduate Students</h2>
<table class="data-table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Degree</th>
      <th>Year</th>
      <th>Topic</th>
      <th>Status</th>
      <th>Lang.</th>
    </tr>
  </thead>
  <tbody>
    {% for student in doctoral %}
      <tr>
        <td>{{ student.name }}</td>
        <td>{{ student.degree }}</td>
        <td>{{ student.year or "" }}</td>
        <td>{{ student.topic }}</td>
        <td>{{ student.status }}</td>
        <td>{{ student | languages }}</td>
      </tr>
    {% endfor %}
    {% for student in masters %}
      <tr>
        <td>{{ student.name }}</td>
        <td>{{ student.degree }}</td>
        <td>{{ student.year or "" }}</td>
        <td>{{ student.topic }}</td>
        <td>{{ student.status }}</td>
        <td>{{ student | languages }}</td>
      </tr>
    {% endfor %}
  </tbody>
</table>
</section>

<section class="rule-section">
  <h2>Undergraduate Projects</h2>
  <ul class="plain-list compact-list">
    {% for student in undergraduate %}
      <li>
        <strong>{{ student.name }}</strong>
        <span>{% if student.year %}{{ student.year }}. {% endif %}{{ student.topic }}</span>
      </li>
    {% endfor %}
  </ul>
</section>

<section class="rule-section">
  <h2>Student Writings</h2>
  <ul class="plain-list compact-list">
    {% for item in writings %}
      <li>
        {% if item.links and item.links.length %}
          <a href="{{ item.links[0].url }}">{{ item.topic }}</a>
        {% else %}
          {{ item.topic }}
        {% endif %}
        {% if item.name %}<span>{{ item.name }}</span>{% endif %}
      </li>
    {% endfor %}
  </ul>
</section>
