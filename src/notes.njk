<h1>Notes</h1>
<p class="lede narrow">Selected notes and teaching materials, organized by topic and language.</p>

{% set analysisNotes = notes | where("category", "analysis-calculus-ode") %}
{% set complexNotes = notes | where("category", "complex-analysis") %}
{% set pdeNotes = notes | where("category", "pde") %}

<section class="rule-section">
  <h2>Calculus, Analysis, and ODE</h2>
  <ul class="plain-list">
    {% for note in analysisNotes %}
      <li>{% if note.links[0].url %}<a href="{{ note.links[0].url }}">{{ note.title }}</a>{% else %}{{ note.title }}{% endif %}</li>
    {% endfor %}
  </ul>
</section>

<section class="rule-section">
  <h2>Complex Analysis</h2>
  <ul class="plain-list">
    {% for note in complexNotes %}
      <li>{% if note.links[0].url %}<a href="{{ note.links[0].url }}">{{ note.title }}</a>{% else %}{{ note.title }}{% endif %}</li>
    {% endfor %}
  </ul>
</section>

<section class="rule-section">
  <h2>Partial Differential Equations</h2>
  <ul class="plain-list">
    {% for note in pdeNotes %}
      <li>{% if note.links[0].url %}<a href="{{ note.links[0].url }}">{{ note.title }}</a>{% else %}{{ note.title }}{% endif %}</li>
  {% endfor %}
  </ul>
</section>

<section class="rule-section">
  <h2>Mongolian Materials</h2>
  <p>English is the main language of the site. Mongolian notes are included as first-class teaching materials where they fit the public archive.</p>
</section>
