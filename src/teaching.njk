layout: layouts/base.njk
title: Teaching
permalink: /teaching/
---

<h1>Teaching</h1>
<p class="lede narrow">Recent and selected courses, short courses, and archived teaching materials.</p>

<section class="rule-section">
  <h2>Teaching Archive</h2>
  <p>Course pages and local materials are linked when a maintained local archive page exists.</p>
</section>

<table class="data-table teaching-table">
  <thead>
    <tr>
      <th>Course</th>
      <th>Title</th>
      <th>Term</th>
      <th>Institution</th>
    </tr>
  </thead>
  <tbody>
    {% for course in courses | teachingArchive %}
      {% set courseUrl = course | localCourseUrl %}
      <tr>
        <td>{{ course | courseCode }}</td>
        <td>{% if courseUrl %}<a href="{{ courseUrl }}">{{ course.title }}</a>{% else %}{{ course.title }}{% endif %}</td>
        <td>{{ course | courseTerm }}</td>
        <td>{{ course | courseInstitution }}</td>
      </tr>
    {% endfor %}
  </tbody>
</table>

<section class="rule-section">
  <h2>Course Pages and Materials</h2>
  <p>Local course pages preserve selected schedules, notes, assignments, and downloadable material where they are available.</p>
</section>
