---
layout: layouts/base.njk
title: Teaching
permalink: /teaching/
---

<h1>Teaching</h1>
<p class="lede narrow">Selected course materials and teaching records, with past McGill courses organized as an archive and Mongolian-language material included where appropriate.</p>

{% set mcgillCourses = courses | where("institution", "McGill University") %}
{% set otherCourses = courses | where("level", "other") %}

<section class="rule-section">
  <h2>McGill Archive</h2>
  <p>Past McGill course pages are part of the teaching archive. The list below records representative courses from that archive.</p>
</section>

<table class="data-table">
  <thead>
    <tr>
      <th>Course</th>
      <th>Title</th>
      <th>Term</th>
      <th>Institution</th>
      <th>Role</th>
      <th>Lang.</th>
    </tr>
  </thead>
  <tbody>
    {% for course in mcgillCourses %}
      <tr>
        <td>{{ course.code or "" }}</td>
        <td>{% if course.url %}<a href="{{ course.url }}">{{ course.title }}</a>{% else %}{{ course.title }}{% endif %}</td>
        <td>{{ course.term.label }}</td>
        <td>{{ course.institution }}</td>
        <td>{{ course.role }}</td>
        <td>{{ course | languages }}</td>
      </tr>
    {% endfor %}
  </tbody>
</table>

<section class="rule-section">
  <h2>Other Teaching</h2>
  <ul class="plain-list">
    {% for course in otherCourses %}
      <li>
        {% if course.url %}<a href="{{ course.url }}">{{ course.title }}</a>{% else %}{{ course.title }}{% endif %}
        <span>{{ course.institution }}{% if course.term.label %}, {{ course.term.label }}{% endif %}</span>
      </li>
    {% endfor %}
  </ul>
</section>
